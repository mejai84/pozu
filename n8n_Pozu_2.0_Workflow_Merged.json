    {
      "parameters": {
        "name": "verificar_producto",
        "description": "Busca ingredientes, alérgenos y precios. Reporta si un producto tiene extras como 'Pollo (+2€)' o requiere salsas.",
        "jsCode": "const nombreProducto = $fromAI('product_name', 'Nombre del producto', 'string');\nconst productos = $('Consultar Catálogo Productos').all();\nconst nombreBuscado = nombreProducto.toLowerCase();\nconst p = productos.find(item => item.json.name?.toLowerCase().includes(nombreBuscado));\n\nif (!p) return `Producto no encontrado.`;\n\nconst item = p.json;\nlet extraInfo = '';\nif (item.name.toLowerCase().includes('hamburguesa')) extraInfo = 'OPCIÓN: Pollo Crujiente (+2€ por unidad).';\nif (item.name.toLowerCase().includes('cesta')) extraInfo = 'OBLIGATORIO: Elegir salsa (Alioli, Brava, Miel y Mostaza, Ketchup).';\n\nreturn `VERIFICADO: ${item.name} | Precio: ${item.price}€ | Alérgenos: ${item.allergens || 'Consultar'} | ${extraInfo}`;"
      },
      "id": "ce3751e1-1135-4fb6-a479-7d12872ddf67",
